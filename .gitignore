# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# deployment artifacts
deploy-temp/
*.zip
app-logs/
app-logs-new/
/portal/backup/
/portal/my-backup/

# generated reports
*.csv

# dev artifacts
bracket-simulation.html
# Squad: ignore runtime state (logs, inbox, sessions)
.squad/orchestration-log/
.squad/log/
.squad/decisions/inbox/
.squad/sessions/
.squad/.scratch/
.squad/.cache/
# Squad: SubSquad activation file (local to this machine)
.squad-workstream
# Squad runtime state stays local; workflows fall back to .ai-team/ when repo-backed squad files are absent.
.squad
# Local Copilot CLI config
.copilot

# PII — CLI scripts with real employee aliases
portal/cli/resolve-aliases.ts
portal/cli/verify-aliases-graph.ts